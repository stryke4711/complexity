---
interface Props {
	lang?: 'en' | 'de';
}

const { lang = Astro.url.pathname.startsWith('/de') ? 'de' : 'en' } = Astro.props;

const isGerman = lang === 'de';
const base = `/${lang}`;

const links = isGerman
	? [
			{ href: `${base}/`, label: 'Home' },
			{ href: `${base}/projects`, label: 'Projekte' },
			{ href: `${base}/photography`, label: 'Fotografie' },
			{ href: `${base}/personal-projects`, label: 'Persönliche Projekte' },
			{ href: `${base}/cats`, label: 'Katzen', icon: '/assets/icons/paw.png' }
		]
	: [
			{ href: `${base}/`, label: 'Home' },
			{ href: `${base}/projects`, label: 'Projects' },
			{ href: `${base}/photography`, label: 'Photography' },
			{ href: `${base}/personal-projects`, label: 'Personal Projects' },
			{ href: `${base}/cats`, label: 'Cats', icon: '/assets/icons/paw.png' }
		];

const switchPath = Astro.url.pathname.replace(/^\/(en|de)/, '');
const alternateLang = isGerman ? 'en' : 'de';
const alternateHref = `/${alternateLang}${switchPath || '/'}`;
---

<header class="site-header">
	<div class="content-wrap header-inner">
		<a class="brand" href={`${base}/`}>Vince</a>
		<nav aria-label="Main navigation">
			<ul class="nav-list">
				{
					links.map((link) => (
						<li>
							<a href={link.href} aria-label={link.label}>
								{link.icon ? (
									<img src={link.icon} alt={link.label} class="nav-icon" />
								) : (
									link.label
								)}
							</a>
						</li>
					))
				}
				<li>
					<a class="lang-switch" href={alternateHref}>
						{isGerman ? 'EN' : 'DE'}
					</a>
				</li>
			</ul>
		</nav>
	</div>
</header>

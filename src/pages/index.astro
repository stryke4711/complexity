---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Classic Starter" description="A clean Astro starter homepage.">
	<section class="hero">
		<h1>Build your website faster</h1>
		<p>
			This is your classic Astro starter package with reusable layout, navigation, footer, and
			ready-to-edit pages.
		</p>
	</section>

	<section class="section">
		<h2>What is included</h2>
		<ul>
			<li>Shared layout with metadata support</li>
			<li>Home, About, and Contact pages</li>
			<li>Simple global styling and responsive navigation</li>
		</ul>
	</section>
</Layout>

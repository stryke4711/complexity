---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Classic Starter" description="Learn more about this website.">
	<section class="hero">
		<h1>About this project</h1>
		<p>
			Use this page to introduce your brand, your work, and your mission. Keep your story concise
			and clear.
		</p>
	</section>

	<section class="section">
		<h2>Quick tips</h2>
		<ul>
			<li>Start with one strong paragraph about who you are.</li>
			<li>Add a short list of services or focus areas.</li>
			<li>Link to your contact page with a clear call to action.</li>
		</ul>
	</section>
</Layout>

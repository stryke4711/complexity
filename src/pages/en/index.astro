---
import Layout from '../../layouts/Layout.astro';
---

<Layout lang="en" title="Home" description="Welcome to my website.">
	<section class="hero">
		<h1>Hi, I am Vince.</h1>
		<p>
			Welcome to my personal website. I build digital projects, share photography, and document the
			things I am currently exploring.
		</p>
	</section>

	<section class="section">
		<h2>About me</h2>
		<p>
			I am a creative builder interested in design, technology, and storytelling. This site is my
			digital base for selected work and ongoing personal ideas.
		</p>
	</section>

	<section class="section">
		<h2>Flagship projects (3)</h2>
		<ul>
			<li><strong>Project One:</strong> Short one-line description of your best project.</li>
			<li><strong>Project Two:</strong> Short one-line description of another key project.</li>
			<li><strong>Project Three:</strong> Short one-line description of a third featured project.</li>
		</ul>
		<p><a href="/en/projects">View all projects</a></p>
	</section>

	<section class="section">
		<h2>Photography</h2>
		<p>
			A curated selection of photos, visual studies, and moments. You can use this section as an
			entry point to your gallery.
		</p>
		<p><a href="/en/photography">Open photography page</a></p>
	</section>

	<section class="section">
		<h2>Personal projects</h2>
		<p>
			Experiments, prototypes, and side quests that may not be client work but still matter for
			learning and growth.
		</p>
		<p><a href="/en/personal-projects">Explore personal projects</a></p>
	</section>

	<section class="section">
		<h2>Contact</h2>
		<p>
			If you want to collaborate, ask a question, or just say hi, feel free to get in touch via
			email.
		</p>
		<p><a href="mailto:hello@example.com">hello@example.com</a></p>
	</section>
</Layout>
